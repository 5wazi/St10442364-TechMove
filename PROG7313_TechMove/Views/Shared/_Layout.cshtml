<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechMove</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <style>
        a.navbar-brand {
            white-space: normal;
            text-align: left;
            word-break: break-all;
        }

        a {
            color: var(--accent);
        }

        .btn-primary {
            color: #fff;
            background-color: var(--accent);
            border-color: var(--accent);
        }

            .btn-primary:hover, .btn-primary:focus {
                background-color: var(--accent-dark);
                border-color: var(--accent-dark);
            }

        .nav-pills .nav-link.active, .nav-pills .show > .nav-link {
            color: #fff;
            background-color: var(--accent);
            border-color: var(--accent);
        }

        .border-top {
            border-top: 1px solid var(--border);
        }

        .border-bottom {
            border-bottom: 1px solid var(--border);
        }

        .box-shadow {
            box-shadow: 0 .25rem .75rem rgba(0, 0, 0, .06);
        }

        button.accept-policy {
            font-size: 1rem;
            line-height: inherit;
        }

        .footer {
            position: absolute;
            bottom: 0;
            width: 100%;
            white-space: nowrap;
            line-height: 60px;
        }

        :root {
            --sidebar-bg: #0f172a;
            --navbar-bg: #0f172a;
            --accent: #c9a84c;
            --accent-dark: #a8873a;
            --accent-glow: rgba(201, 168, 76, 0.12);
            --surface: #f1f4f8;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --sidebar-width: 232px;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background-color: var(--surface);
            color: var(--text-main);
            margin: 0;
        }

        /* ── TOP NAVBAR ── */
        .navbar {
            background-color: var(--navbar-bg) !important;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding: 0 1.5rem;
            height: 58px;
            position: sticky;
            top: 0;
            z-index: 1030;
            box-shadow: 0 2px 16px rgba(0,0,0,0.35);
        }

        .navbar-brand {
            font-family: 'IBM Plex Sans', sans-serif;
            font-weight: 600;
            font-size: 1.15rem;
            color: #fff !important;
            letter-spacing: 0.2px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

            .navbar-brand .brand-icon {
                background: var(--accent);
                color: #0f172a;
                width: 34px;
                height: 34px;
                border-radius: 6px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
                flex-shrink: 0;
            }

            .navbar-brand .brand-sub {
                font-family: 'IBM Plex Sans', sans-serif;
                font-weight: 300;
                font-size: 0.72rem;
                color: #94a3b8;
                display: block;
                line-height: 1;
                margin-top: 2px;
                letter-spacing: 0.3px;
            }

        .navbar-status {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: #64748b;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 6px rgba(34,197,94,0.6);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.35;
            }
        }

        .admin-chip {
            display: flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 4px 12px 4px 6px;
            color: #cbd5e1;
            font-size: 0.8rem;
        }

        .admin-avatar {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #1e293b;
            border: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
            color: #94a3b8;
        }

        /* ── LAYOUT ── */
        .app-body {
            display: flex;
            min-height: calc(100vh - 58px);
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: var(--sidebar-width);
            background-color: var(--sidebar-bg);
            flex-shrink: 0;
            padding: 1.2rem 0.8rem;
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255,255,255,0.05);
        }

        .sidebar-heading {
            font-family: 'IBM Plex Sans', sans-serif;
            color: #334155;
            font-size: 0.62rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            padding: 0.8rem 0.6rem 0.4rem;
            margin-top: 0.5rem;
        }

        .sidebar .nav-link {
            color: #64748b;
            padding: 0.55rem 0.8rem;
            border-radius: 6px;
            margin-bottom: 2px;
            font-size: 0.875rem;
            font-weight: 400;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: background 0.18s, color 0.18s, transform 0.15s;
            text-decoration: none;
        }

            .sidebar .nav-link i {
                font-size: 1rem;
                width: 20px;
                text-align: center;
                flex-shrink: 0;
            }

            .sidebar .nav-link:hover {
                background-color: rgba(255,255,255,0.05);
                color: #e2e8f0;
                transform: translateX(2px);
            }

            .sidebar .nav-link.active {
                background-color: var(--accent-glow);
                color: var(--accent);
                border-left: 2px solid var(--accent);
                padding-left: calc(0.8rem - 2px);
            }

        /* ── MAIN CONTENT ── */
        .main-content {
            flex: 1;
            padding: 2rem 2.5rem;
            max-width: 100%;
            overflow-x: hidden;
        }

        /* ── ALERTS ── */
        .alert-success {
            background: #f0fdf4;
            border-color: #bbf7d0;
            color: #166534;
            border-radius: 8px;
        }

        .alert-danger {
            background: #fef2f2;
            border-color: #fca5a5;
            color: #7f1d1d;
            border-radius: 8px;
        }

        /* ── FOOTER ── */
        footer {
            background-color: var(--sidebar-bg);
            color: #334155;
            font-size: 0.78rem;
            border-top: 1px solid rgba(255,255,255,0.04);
            padding: 1rem 0;
            text-align: center;
            letter-spacing: 0.3px;
        }

        /* ── GLOBAL CARD ── */
        .card {
            border: 1px solid var(--border);
            border-radius: 10px;
            background: var(--card-bg);
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }

        /* ── GLOBAL BUTTONS ── */
        .btn-primary {
            background-color: var(--accent);
            border-color: var(--accent);
            color: #0f172a;
            font-weight: 600;
            border-radius: 6px;
            padding: 0.45rem 1.1rem;
            transition: background 0.2s, box-shadow 0.2s;
            font-size: 0.875rem;
        }

            .btn-primary:hover, .btn-primary:focus {
                background-color: var(--accent-dark);
                border-color: var(--accent-dark);
                box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.2);
                color: #0f172a;
            }

        .btn-secondary {
            background-color: #f1f5f9;
            border-color: #e2e8f0;
            color: var(--text-main);
            border-radius: 6px;
            font-size: 0.875rem;
        }

            .btn-secondary:hover {
                background-color: #e2e8f0;
                border-color: #cbd5e1;
                color: var(--text-main);
            }

        .btn-danger {
            border-radius: 6px;
        }

        /* ── MOBILE ── */
        @@media (max-width: 767px) {
            .sidebar {
                display: none;
            }

            .main-content {
                padding: 1.2rem;
            }
        }
    </style>
</head>
<body>

    <!-- Top Navbar -->
    <nav class="navbar navbar-dark">
        <div class="container-fluid px-0">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <div class="brand-icon"><i class="bi bi-truck"></i></div>
                <div>
                    TechMove Logistics
                    <span class="brand-sub">Enteprise Platform</span>
                </div>
            </a>
            <div class="navbar-status">
                <div class="status-badge">
                    <span class="status-dot"></span>
                    System Online
                </div>
                <div class="admin-chip">
                    <div class="admin-avatar"><i class="bi bi-person-fill"></i></div>
                    Admin
                </div>
            </div>
        </div>
    </nav>

    <div class="app-body">

        <!-- Sidebar -->
        <nav class="sidebar d-none d-md-flex">

            <div class="sidebar-heading">Main Menu</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door"></i> Dashboard
                    </a>
                </li>
            </ul>

            <div class="sidebar-heading">Logistics</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")"
                       asp-controller="Clients" asp-action="Index">
                        <i class="bi bi-people"></i> Clients
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "")"
                       asp-controller="Contracts" asp-action="Index">
                        <i class="bi bi-file-earmark-text"></i> Contracts
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequests" ? "active" : "")"
                       asp-controller="ServiceRequests" asp-action="Index">
                        <i class="bi bi-clipboard-check"></i> Service Requests
                    </a>
                </li>
            </ul>

            <div class="sidebar-heading">Finance</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="bi bi-currency-exchange"></i> Currency Rates
                    </a>
                </li>
            </ul>

        </nav>

        <!-- Main Content -->
        <main class="main-content">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>

    </div>

    <!-- Footer -->
    <footer>
        <div class="container">
            &copy; 2026 TechMove Logistics — Global Logistics Management System
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
