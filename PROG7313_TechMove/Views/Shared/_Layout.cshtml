<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechMove</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <style>
        a.navbar-brand {
            white-space: normal;
            text-align: left;
            word-break: break-all;
        }

        a {
            color: var(--accent);
        }

        .btn-primary {
            color: #0f172a;
            background-color: var(--accent);
            border-color: var(--accent);
        }

            .btn-primary:hover, .btn-primary:focus {
                background-color: var(--accent-dark);
                border-color: var(--accent-dark);
            }

        .nav-pills .nav-link.active, .nav-pills .show > .nav-link {
            color: #fff;
            background-color: var(--accent);
            border-color: var(--accent);
        }

        .border-top {
            border-top: 1px solid var(--border);
        }

        .border-bottom {
            border-bottom: 1px solid var(--border);
        }

        .box-shadow {
            box-shadow: 0 .25rem .75rem rgba(0,0,0,.06);
        }

        button.accept-policy {
            font-size: 1rem;
            line-height: inherit;
        }

        :root {
            --navbar-bg: #0f172a;
            --accent: #c9a84c;
            --accent-dark: #a8873a;
            --accent-glow: rgba(201, 168, 76, 0.12);
            --surface: #f1f4f8;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background-color: var(--surface);
            color: var(--text-main);
            margin: 0;
        }

        /* ── TOP BAR (two rows) ─────────────────────────────────────────────── */
        .top-bar {
            background-color: var(--navbar-bg);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            position: sticky;
            top: 0;
            z-index: 1030;
            box-shadow: 0 2px 16px rgba(0,0,0,0.35);
        }

        /* Row 1 — brand + status */
        .top-bar-brand {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 1.5rem;
            height: 54px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .navbar-brand {
            font-family: 'IBM Plex Sans', sans-serif;
            font-weight: 600;
            font-size: 1.15rem;
            color: #fff !important;
            letter-spacing: 0.2px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

            .navbar-brand .brand-icon {
                background: var(--accent);
                color: #0f172a;
                width: 34px;
                height: 34px;
                border-radius: 6px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1rem;
                flex-shrink: 0;
            }

            .navbar-brand .brand-sub {
                font-weight: 300;
                font-size: 0.72rem;
                color: #94a3b8;
                display: block;
                line-height: 1;
                margin-top: 2px;
                letter-spacing: 0.3px;
            }

        .navbar-status {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: #64748b;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 6px rgba(34,197,94,0.6);
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.35;
            }
        }

        .admin-chip {
            display: flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 4px 12px 4px 6px;
            color: #cbd5e1;
            font-size: 0.8rem;
        }

        .admin-avatar {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: #1e293b;
            border: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
            color: #94a3b8;
        }

        /* Mobile hamburger button */
        .nav-toggler {
            display: none;
            background: none;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 6px;
            color: #94a3b8;
            padding: 5px 9px;
            cursor: pointer;
            font-size: 1.1rem;
            line-height: 1;
        }

        /* Row 2 — nav links */
        .top-bar-nav {
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            height: 42px;
            gap: 2px;
        }

        /* Thin section labels between groups */
        .nav-group-label {
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1.6px;
            color: #334155;
            padding: 0 0.6rem 0 0.9rem;
            white-space: nowrap;
            user-select: none;
            flex-shrink: 0;
        }

        /* Vertical divider between groups */
        .nav-divider {
            width: 1px;
            height: 18px;
            background: rgba(255,255,255,0.08);
            margin: 0 0.4rem;
            flex-shrink: 0;
        }

        .top-nav-link {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #64748b;
            font-size: 0.82rem;
            font-weight: 400;
            padding: 0 0.75rem;
            height: 42px;
            text-decoration: none;
            border-bottom: 2px solid transparent;
            white-space: nowrap;
            transition: color 0.15s, border-color 0.15s;
            flex-shrink: 0;
        }

            .top-nav-link i {
                font-size: 0.9rem;
            }

            .top-nav-link:hover {
                color: #e2e8f0;
                border-bottom-color: rgba(201,168,76,0.4);
            }

            .top-nav-link.active {
                color: var(--accent);
                border-bottom-color: var(--accent);
                font-weight: 500;
            }

        /* ── LAYOUT ── */
        .app-body {
            min-height: calc(100vh - 96px - 52px);
        }

        /* ── MAIN CONTENT ── */
        .main-content {
            padding: 2rem 2.5rem;
            max-width: 100%;
            overflow-x: hidden;
        }

        /* ── ALERTS ── */
        .alert-success {
            background: #f0fdf4;
            border-color: #bbf7d0;
            color: #166534;
            border-radius: 8px;
        }

        .alert-danger {
            background: #fef2f2;
            border-color: #fca5a5;
            color: #7f1d1d;
            border-radius: 8px;
        }

        /* ── FOOTER ── */
        footer {
            background-color: var(--navbar-bg);
            color: #334155;
            font-size: 0.78rem;
            border-top: 1px solid rgba(255,255,255,0.04);
            padding: 1rem 0;
            text-align: center;
            letter-spacing: 0.3px;
        }

        /* ── GLOBAL CARD ── */
        .card {
            border: 1px solid var(--border);
            border-radius: 10px;
            background: var(--card-bg);
            box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        }

        /* ── GLOBAL BUTTONS ── */
        .btn-primary {
            background-color: var(--accent);
            border-color: var(--accent);
            color: #0f172a;
            font-weight: 600;
            border-radius: 6px;
            padding: 0.45rem 1.1rem;
            transition: background 0.2s, box-shadow 0.2s;
            font-size: 0.875rem;
        }

            .btn-primary:hover, .btn-primary:focus {
                background-color: var(--accent-dark);
                border-color: var(--accent-dark);
                box-shadow: 0 0 0 3px rgba(201,168,76,0.2);
                color: #0f172a;
            }

        .btn-secondary {
            background-color: #f1f5f9;
            border-color: #e2e8f0;
            color: var(--text-main);
            border-radius: 6px;
            font-size: 0.875rem;
        }

            .btn-secondary:hover {
                background-color: #e2e8f0;
                border-color: #cbd5e1;
                color: var(--text-main);
            }

        .btn-danger {
            border-radius: 6px;
        }

        /* ── MOBILE ── */
        @@media (max-width: 767px) {
            .nav-toggler {
                display: block;
            }

            .navbar-status {
                display: none !important;
            }
            /* Nav row collapses by default on mobile */
            .top-bar-nav {
                flex-direction: column;
                height: auto;
                align-items: flex-start;
                padding: 0.4rem 1rem 0.6rem;
                gap: 0;
                overflow: hidden;
                max-height: 0;
                transition: max-height 0.25s ease;
            }

                .top-bar-nav.open {
                    max-height: 300px;
                }

            .top-nav-link {
                height: 40px;
                width: 100%;
                border-bottom: none;
                border-left: 2px solid transparent;
                padding-left: 0.6rem;
            }

                .top-nav-link.active {
                    border-left-color: var(--accent);
                    border-bottom-color: transparent;
                }

            .nav-group-label,
            .nav-divider {
                display: none;
            }

            .main-content {
                padding: 1.2rem;
            }
        }
    </style>
</head>
<body>

    <!-- ── Top Bar ── -->
    <header class="top-bar">

        <!-- Row 1: brand + status -->
        <div class="top-bar-brand">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <div class="brand-icon"><i class="bi bi-truck"></i></div>
                <div>
                    TechMove Logistics
                    <span class="brand-sub">Enterprise Platform</span>
                </div>
            </a>

            <button class="nav-toggler" id="navToggler" aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>

            <div class="navbar-status">
                <div class="status-badge">
                    <span class="status-dot"></span>
                    System Online
                </div>
                <div class="admin-chip">
                    <div class="admin-avatar"><i class="bi bi-person-fill"></i></div>
                    Admin
                </div>
            </div>
        </div>

        <!-- Row 2: nav links -->
        <nav class="top-bar-nav" id="topNav">

            

            <a class="top-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door"></i> Dashboard
            </a>

            <div class="nav-divider"></div>
            

            <a class="top-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clients" ? "active" : "")"
               asp-controller="Clients" asp-action="Index">
                <i class="bi bi-people"></i> Clients
            </a>

            <a class="top-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "")"
               asp-controller="Contracts" asp-action="Index">
                <i class="bi bi-file-earmark-text"></i> Contracts
            </a>

            <a class="top-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequests" ? "active" : "")"
               asp-controller="ServiceRequests" asp-action="Index">
                <i class="bi bi-clipboard-check"></i> Service Requests
            </a>

            

        </nav>
    </header>

    <!-- Main Content -->
    <div class="app-body">
        <main class="main-content">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container">
            &copy; 2026 TechMove Logistics — Global Logistics Management System
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Desktop: nav row always visible. Mobile: toggle on hamburger click.
        (function () {
            var nav     = document.getElementById('topNav');
            var toggler = document.getElementById('navToggler');

            toggler.addEventListener('click', function () {
                nav.classList.toggle('open');
            });

            // On resize to desktop, remove the mobile open/close class
            window.addEventListener('resize', function () {
                if (window.innerWidth >= 768) {
                    nav.classList.remove('open');
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
