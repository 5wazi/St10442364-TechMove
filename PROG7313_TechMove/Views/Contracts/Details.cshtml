@model PROG7313_TechMove.Models.Contract
@{
    ViewData["Title"] = $"Contract #{Model.Id}";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
    }

    .page-title-block .accent-line {
        display: inline-block;
        width: 32px;
        height: 2px;
        background: var(--accent);
        border-radius: 2px;
        margin-bottom: 0.5rem;
    }

    .page-title-block h2 {
        font-family: 'DM Serif Display', serif;
        font-weight: 400;
        font-size: 1.7rem;
        color: var(--text-main);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-title-block h2 i {
            color: var(--accent);
            font-size: 1.3rem;
        }

    /* Info & Action Cards */
    .info-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        height: 100%;
    }

    .info-card-header {
        background: #0f172a;
        padding: 0.85rem 1.3rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: 'IBM Plex Sans', sans-serif;
        font-weight: 500;
        font-size: 0.68rem;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 1.4px;
    }

        .info-card-header i {
            color: var(--accent);
        }

        .info-card-header .header-left {
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .info-table {
        width: 100%;
        border-collapse: collapse;
    }

        .info-table tr {
            border-bottom: 1px solid #f8fafc;
        }

            .info-table tr:last-child {
                border-bottom: none;
            }

        .info-table th {
            padding: 0.85rem 1.3rem;
            font-size: 0.75rem;
            font-weight: 500;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            width: 38%;
            vertical-align: top;
        }

        .info-table td {
            padding: 0.85rem 1.3rem 0.85rem 0;
            font-size: 0.875rem;
            color: var(--text-main);
            vertical-align: top;
        }

    /* Status & Service Level badges */
    .status-badge {
        display: inline-block;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.73rem;
        font-weight: 500;
    }

    .status-active {
        background: #f0fdf4;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .status-expired {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fca5a5;
    }

    .status-onhold {
        background: #fffbeb;
        color: #92400e;
        border: 1px solid #fde68a;
    }

    .status-inactive {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
    }

    .badge-gold {
        background: rgba(201,168,76,0.12);
        color: #92701a;
        border: 1px solid rgba(201,168,76,0.3);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.73rem;
        font-weight: 500;
    }

    .badge-silver {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e1;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.73rem;
        font-weight: 500;
    }

    .badge-default {
        background: #1e293b;
        color: #94a3b8;
        border: 1px solid #334155;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 0.73rem;
        font-weight: 500;
    }

    /* Action card sections */
    .action-section {
        padding: 1.2rem 1.3rem;
        border-bottom: 1px solid #f1f5f9;
    }

        .action-section:last-child {
            border-bottom: none;
        }

    .action-section-label {
        font-size: 0.72rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #94a3b8;
        margin-bottom: 0.75rem;
    }

    .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-size: 0.875rem;
        background: #f8fafc;
        color: var(--text-main);
        padding: 0.5rem 0.85rem;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.15);
            background: #fff;
            outline: none;
        }

    .btn-update {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        border-radius: 6px;
        padding: 0.48rem 1rem;
        font-size: 0.82rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
        cursor: pointer;
    }

        .btn-update:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: rgba(201, 168, 76, 0.05);
        }

    .pdf-block {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .pdf-icon {
        font-size: 1.6rem;
        color: #ef4444;
        flex-shrink: 0;
    }

    .pdf-filename {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 4px;
    }

    .btn-download {
        background: transparent;
        border: 1px solid #fca5a5;
        color: #ef4444;
        border-radius: 6px;
        padding: 3px 12px;
        font-size: 0.78rem;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: background 0.15s, color 0.15s;
    }

        .btn-download:hover {
            background: #fef2f2;
            color: #b91c1c;
        }

    .no-file-note {
        font-size: 0.83rem;
        color: #94a3b8;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .alert-locked {
        background: #fffbeb;
        border: 1px solid #fde68a;
        color: #92400e;
        border-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.83rem;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    /* Service Requests Table */
    .sr-card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }

    .sr-table {
        width: 100%;
        border-collapse: collapse;
    }

        .sr-table thead tr {
            background: #0f172a;
        }

        .sr-table thead th {
            font-family: 'IBM Plex Sans', sans-serif;
            font-weight: 500;
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 1.4px;
            color: #64748b;
            padding: 0.85rem 1.1rem;
            border: none;
        }

        .sr-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.15s;
        }

            .sr-table tbody tr:last-child {
                border-bottom: none;
            }

            .sr-table tbody tr:hover {
                background: #f8fafc;
            }

        .sr-table tbody td {
            padding: 0.8rem 1.1rem;
            font-size: 0.86rem;
            color: #374151;
            vertical-align: middle;
        }

    .sr-id {
        font-size: 0.73rem;
        color: #94a3b8;
        font-weight: 500;
    }

    .rate-cell {
        font-size: 0.78rem;
        color: #94a3b8;
    }

    .sr-status-completed {
        background: #f0fdf4;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .sr-status-cancelled {
        background: #fef2f2;
        color: #b91c1c;
        border: 1px solid #fca5a5;
    }

    .sr-status-inprogress {
        background: rgba(201,168,76,0.1);
        color: #92701a;
        border: 1px solid rgba(201,168,76,0.3);
    }

    .sr-status-default {
        background: #f1f5f9;
        color: #64748b;
        border: 1px solid #e2e8f0;
    }

    .btn-view {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        border-radius: 6px;
        padding: 4px 12px;
        font-size: 0.76rem;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: border-color 0.15s, color 0.15s, background 0.15s;
    }

        .btn-view:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: rgba(201, 168, 76, 0.05);
        }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: #94a3b8;
        font-size: 0.875rem;
    }

        .empty-state i {
            font-size: 2rem;
            color: #cbd5e1;
            display: block;
            margin-bottom: 0.75rem;
        }

    .count-chip {
        background: #1e293b;
        color: #64748b;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.7rem;
        font-weight: 500;
    }
</style>

<div class="page-header">
    <div class="page-title-block">
        <div class="accent-line"></div>
        <h2>
            <i class="bi bi-file-earmark-text"></i>
            @Model.Client?.Name
            <span style="font-size: 0.8rem; color: #94a3b8; margin-left: 8px;">
                — Contract #@Model.Id
            </span>
        </h2>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Contracts
    </a>
</div>

<div class="row g-4">

    <!-- Contract Info Card -->
    <div class="col-md-6">
        <div class="info-card">
            <div class="info-card-header">
                <div class="header-left"><i class="bi bi-info-circle"></i> Contract Details</div>
            </div>
            <table class="info-table">
                <tr>
                    <th>Client</th>
                    <td>@Model.Client?.Name</td>
                </tr>
                <tr>
                    <th>Region</th>
                    <td>@Model.Client?.Region</td>
                </tr>
                <tr>
                    <th>Service Level</th>
                    <td>
                        <span class="@(Model.ServiceLevel == "Gold" ? "badge-gold" : Model.ServiceLevel == "Silver" ? "badge-silver" : "badge-default")">
                            @Model.ServiceLevel
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Start Date</th>
                    <td>@Model.StartDate.ToShortDateString()</td>
                </tr>
                <tr>
                    <th>End Date</th>
                    <td>@Model.EndDate.ToShortDateString()</td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td>
                        <span class="status-badge @(Model.Status == ContractStatus.Active ? "status-active" : Model.Status == ContractStatus.Expired ? "status-expired" : Model.Status == ContractStatus.OnHold ? "status-onhold" : "status-inactive")">
                            @Model.Status
                        </span>
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <!-- Actions Card -->
    <div class="col-md-6">
        <div class="info-card">
            <div class="info-card-header">
                <div class="header-left"><i class="bi bi-gear"></i> Actions</div>
            </div>

            <!-- Change Status -->
            <div class="action-section">
                <div class="action-section-label">Change Contract Status</div>
                <form asp-action="ChangeStatus" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 flex-wrap align-items-center">
                    @Html.AntiForgeryToken()
                    <select name="newStatus" class="form-select w-auto">
                        @foreach (var s in Enum.GetValues<ContractStatus>())
                        {
                            <option value="@s" selected="@(Model.Status == s)">@s</option>
                        }
                    </select>
                    <button type="submit" class="btn-update">
                        <i class="bi bi-arrow-repeat"></i> Update Status
                    </button>
                </form>
            </div>

            <!-- Signed Agreement -->
            <div class="action-section">
                <div class="action-section-label">Signed Agreement</div>
                @if (Model.SignedAgreementPath != null)
                {
                    <div class="pdf-block">
                        <i class="bi bi-file-earmark-pdf pdf-icon"></i>
                        <div>
                            <div class="pdf-filename">@Model.SignedAgreementFileName</div>
                            <a asp-action="Download" asp-route-id="@Model.Id" class="btn-download">
                                <i class="bi bi-download"></i> Download PDF
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="no-file-note">
                        <i class="bi bi-exclamation-circle"></i> No signed agreement uploaded yet.
                    </div>
                }
            </div>

            <!-- Service Requests -->
            <div class="action-section">
                <div class="action-section-label">Service Requests</div>
                @if (Model.Status == ContractStatus.Active || Model.Status == ContractStatus.Draft)
                {
                    <a asp-controller="ServiceRequests" asp-action="Create"
                       asp-route-contractId="@Model.Id"
                       class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i> New Service Request
                    </a>
                }
                else
                {
                    <div class="alert-locked">
                        <i class="bi bi-lock"></i>
                        Service requests cannot be created for <strong>@Model.Status</strong> contracts.
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Service Requests Table -->
    <div class="col-12">
        <div class="sr-card">
            <div class="info-card-header">
                <div class="header-left">
                    <i class="bi bi-clipboard-check"></i> Service Requests on this Contract
                </div>
                <span class="count-chip">@Model.ServiceRequests.Count total</span>
            </div>
            @if (!Model.ServiceRequests.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    No service requests yet.
                </div>
            }
            else
            {
                <table class="sr-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Description</th>
                            <th>Cost (USD)</th>
                            <th>Cost (ZAR)</th>
                            <th>Rate Used</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sr in Model.ServiceRequests.OrderByDescending(s => s.CreatedAt))
                        {
                            <tr>
                                <td><span class="sr-id">#@sr.Id</span></td>
                                <td>@sr.Description</td>
                                <td>$@sr.CostUsd.ToString("N2")</td>
                                <td>R @sr.CostZar.ToString("N2")</td>
                                <td><span class="rate-cell">@sr.ExchangeRateUsed.ToString("F4")</span></td>
                                <td>
                                    <span class="status-badge @(sr.Status == ServiceRequestStatus.Completed ? "sr-status-completed" : sr.Status == ServiceRequestStatus.Cancelled ? "sr-status-cancelled" : sr.Status == ServiceRequestStatus.InProgress ? "sr-status-inprogress" : "sr-status-default")">
                                        @sr.Status
                                    </span>
                                </td>
                                <td style="font-size:0.8rem; color:#94a3b8;">@sr.CreatedAt.ToShortDateString()</td>
                                <td>
                                    <a asp-controller="ServiceRequests" asp-action="Details"
                                       asp-route-id="@sr.Id" class="btn-view">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>

@using PROG7313_TechMove.Models
